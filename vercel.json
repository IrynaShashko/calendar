{
  "builds": [
    {
      "src": "server/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "config": {
        "distDir": "dist"
      },
      "src": "client/package.json",
      "use": "@vercel/static-build"
    }
  ],
  "rewrites": [
    {
      "destination": "server/src/index.ts",
      "source": "/api-docs/(.*)"
    },
    {
      "destination": "server/src/index.ts",
      "source": "/api-docs"
    },
    {
      "destination": "server/src/index.ts",
      "source": "/api/(.*)"
    },
    {
      "destination": "client/$1",
      "source": "/(.*)"
    }
  ],
  "version": 2
}